{
    "name": "gemorroj/archive7z",
    "description": "7z cli wrapper",
    "keywords": ["7z","archive","p7zip","7-zip","7zip"],
    "type": "library",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Gemorroj"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/process": "^7.4||^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5||^12.5",
        "friendsofphp/php-cs-fixer": "^3.93",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Archive7z\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Archive7z\\Tests\\": "tests/"
        }
    }
}
