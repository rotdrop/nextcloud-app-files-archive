{
  "minimum-stability": "dev",
  "platform": {
    "php": "8.4"
  },
  "sort-packages": true,
  "require-dev": {
    "cweagans/composer-patches": "^1.7",
    "phpmd/phpmd": "3.x-dev"
  },
  "extra": {
    "patches": {
      "phpmd/phpmd": {
        "Fix defining the default command": "../../composer-patches/phpmd/phpmd/fix-set-default-command.patch"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "cweagans/composer-patches": true
    }
  }
}
