{
  "platform": {
    "php": "8.4"
  },
  "sort-packages": true,
  "require-dev": {
    "cweagans/composer-patches": "^1.7",
    "squizlabs/php_codesniffer": "^4.0.0"
  },
  "config": {
    "allow-plugins": {
      "cweagans/composer-patches": true
    }
  },
  "extra": {
    "patches": {
      "squizlabs/php_codesniffer": {
        "Allow short variable names for int and bool": "../../composer-patches/squizlabs/php_codesniffer/allow-short-variable-names.patch",
        "Allow nullable short-hand": "../../composer-patches/squizlabs/php_codesniffer/allow-nullable-shorthand.patch"
      }
    }
  }
}
